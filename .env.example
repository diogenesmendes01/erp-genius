# Banco de dados PostgreSQL (local ou Neon/Supabase)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/erp_genius?schema=public"

# Auth.js — gere um segredo com: npx auth secret  (ou: openssl rand -base64 32)
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"
