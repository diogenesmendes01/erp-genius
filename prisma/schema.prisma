// ERP Genius — schema modelado em EVENTOS + estado (não em telas).
// Espinha dorsal: tabela `Evento` (audit/event log append-only).
// Regra: Evento = auditoria; tabelas tipadas (ex.: AjusteFinanceiro) = relatório.
// Evolução futura (NÃO V0): Papel enum[] -> tabela UsuarioPapel (escopo por país);
//   unificar Lead/Aluno/Responsavel sob uma entidade Pessoa/Contato.
// Ver docs/02-arquitetura.md e docs/09-fase0-telas.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ACESSO
// ============================================================

enum Papel {
  ADMINISTRADOR
  GERENTE_COMERCIAL
  VENDEDOR
  GERENTE_PEDAGOGICO
  PROFESSOR
  FINANCEIRO
  SECRETARIA_ACADEMICA
}

model Usuario {
  id                String    @id @default(cuid())
  nome              String
  email             String    @unique
  senhaHash         String
  ativo             Boolean   @default(true)
  papeis            Papel[] // multi-papel. V2: migrar p/ tabela UsuarioPapel (permissões granulares / por país)
  limiteDescontoPct Float? // null = sem limite (Admin)
  // dados pessoais (ex.: professores importados — doc 23). Opcionais.
  telefoneE164      String?
  documento         String?
  nascimento        DateTime?
  genero            Genero?
  ultimoAcesso      DateTime?
  criadoEm          DateTime  @default(now())

  leads         Lead[]              @relation("VendedorLeads")
  experimentais Lead[]              @relation("ProfessorExperimentais") // experimentais (leads) sob responsabilidade do professor (Issue #13)
  turmas        Turma[]             @relation("ProfessorTurmas")
  comissoes     Comissao[]
  eventos       Evento[]            @relation("AutorEventos")
  aprovacoes    Aprovacao[]         @relation("SolicitanteAprovacoes")
  aprovadasPor  Aprovacao[]         @relation("AprovadorAprovacoes")
  ajustes       AjusteFinanceiro[]  @relation("AutorAjustes")
  movimentacoes MovimentacaoAluno[] @relation("AutorMovimentacoes")
}

// ============================================================
// PAÍS / MERCADO (espinha dorsal do multi-país)
// ============================================================

enum StatusPais {
  RASCUNHO
  ATIVO
  PAUSADO
  ENCERRADO
}

model Pais {
  id         String     @id @default(cuid())
  nome       String
  codigoISO  String     @unique
  moedaLocal String // ex.: CRC, USD, MXN
  ddi        String // ex.: +506
  fuso       String     @default("America/Sao_Paulo")
  idioma     String     @default("es")
  status     StatusPais @default(RASCUNHO)
  criadoEm   DateTime   @default(now())

  tiposDocumento TipoDocumento[]
  produtosPais   ProdutoPais[]
  precos         PrecoReferencia[]
  alunos         Aluno[]
  leads          Lead[]
  matriculas     Matricula[]
}

model TipoDocumento {
  id        String  @id @default(cuid())
  paisId    String
  pais      Pais    @relation(fields: [paisId], references: [id])
  nome      String // CPF, DNI, CURP, Cédula, Passaporte...
  validador String // nome do validador: cpf, curp, cedula_cr, passaporte...
  alunos    Aluno[] // alunos que escolheram este tipo de documento (doc 04)
}

// ============================================================
// CATÁLOGO
// ============================================================

enum Segmento {
  ADULTO
  KIDS
  TEENS
  EMPRESA
}

model Idioma {
  id       String    @id @default(cuid())
  nome     String // Português, Inglês...
  ativo    Boolean   @default(true)
  niveis   Nivel[]
  produtos Produto[]
}

model Modalidade {
  id              String   @id @default(cuid())
  nome            String // Regular, Semi-intensiva, Intensiva, Super-intensiva, Particular, Kids Regular...
  segmento        Segmento @default(ADULTO)
  frequencia      String // 1x/semana, 2x/semana...
  horasAula       Float    @default(2)
  duracaoPorNivel String // "3 meses", "1 mês"...
  aulasPorNivel   Int? // 12, 16, 18, 20...
  minimoAbrir     Int      @default(1)

  produtos Produto[]
  turmas   Turma[]
  precos   PrecoReferencia[]
}

model Nivel {
  id       String @id @default(cuid())
  idiomaId String
  idioma   Idioma @relation(fields: [idiomaId], references: [id])
  codigo   String // Pré A1, A1, A2, B1, B2, C1, C2
  ordem    Int

  turmas Turma[]
}

// Produto vendável = idioma + modalidade
model Produto {
  id           String            @id @default(cuid())
  idiomaId     String
  idioma       Idioma            @relation(fields: [idiomaId], references: [id])
  modalidadeId String
  modalidade   Modalidade        @relation(fields: [modalidadeId], references: [id])
  produtosPais ProdutoPais[]
  precos       PrecoReferencia[]
  matriculas   Matricula[]
}

enum TipoCobranca {
  MATRICULA // taxa de matrícula (negociável)
  MENSALIDADE // Regular/Intensivo/Kids… (negociável)
  HORA_PARTICULAR // aulas particulares (cobrança por hora)
  MATERIAL // material didático
  CERTIFICADO // certificado profissional — fixo, só Costa Rica (doc 04)
}

// Disponibilidade do produto por país (catálogo global → país habilita subconjunto).
// O PREÇO mora em PrecoReferencia (tabela tipada), não aqui.
model ProdutoPais {
  id        String  @id @default(cuid())
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  paisId    String
  pais      Pais    @relation(fields: [paisId], references: [id])
  moeda     String
  oferecido Boolean @default(true)

  @@unique([produtoId, paisId])
}

// PREÇO TIPADO (decisão P5, doc 15): País + Produto + Modalidade + TipoCobrança = preço.
// modalidadeId é explícito (apesar de derivável de Produto) p/ relatório/seed simples.
// moeda gravada também aqui (vem do país) para fidelidade histórica.
model PrecoReferencia {
  id           String       @id @default(cuid())
  paisId       String
  pais         Pais         @relation(fields: [paisId], references: [id])
  produtoId    String
  produto      Produto      @relation(fields: [produtoId], references: [id])
  modalidadeId String
  modalidade   Modalidade   @relation(fields: [modalidadeId], references: [id])
  tipoCobranca TipoCobranca
  valor        Float
  moeda        String
  ativo        Boolean      @default(true)
  versaoEstudo String?
  vigenteDesde DateTime     @default(now())
  criadoEm     DateTime     @default(now())

  // Integridade (issue #1): no máx. UM preço ATIVO por país+produto+modalidade+tipoCobrança.
  // Índice único PARCIAL (só ativo=true) — mora na migration `integridade_alocacao_preco`
  // (UNIQUE ... WHERE "ativo"). O histórico desativado (supersede) permanece livre.
  @@index([paisId, produtoId, modalidadeId, tipoCobranca])
  @@index([ativo])
  // Proteção lógica: no máximo UM preço ATIVO por combinação
  // (país + produto + modalidade + tipo de cobrança). Como Prisma não suporta
  // índice único parcial, ele é criado por SQL na migration
  // 20260622120000_preco_ativo_unico (partial unique index WHERE ativo).
}

// ============================================================
// TURMAS
// ============================================================

enum StatusTurma {
  PLANEJADA
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
}

model Turma {
  id           String      @id @default(cuid())
  codigo       String?     @unique // T-000001
  nome         String? // nome livre da turma (a escola batiza como quiser: "Salvador", "Particular Ronny"...)
  modalidadeId String
  modalidade   Modalidade  @relation(fields: [modalidadeId], references: [id])
  nivelId      String
  nivel        Nivel       @relation(fields: [nivelId], references: [id])
  professorId  String?
  professor    Usuario?    @relation("ProfessorTurmas", fields: [professorId], references: [id])
  online       Boolean     @default(true) // online (hoje) × presencial (futuro) — não há "sede" física
  // Agenda da turma (calendário real — doc 06): dias da semana + horário. O nº de dias
  // deve casar com a frequência da modalidade (1x/2x/3x/5x por semana). `diasHorario` é o
  // rótulo DERIVADO (ex.: "Seg, Qua, Sex · 19:00") mantido para exibição/compat.
  diasSemana    Int[]      @default([]) // 0=Dom · 1=Seg … 6=Sáb
  horarioInicio String? // "HH:MM" — início da aula
  horarioFim    String? // "HH:MM" — fim da aula
  diasHorario   String? // rótulo derivado (ex.: "Seg, Qua, Sex · 19:00–21:00"); null em turmas antigas
  dataInicio   DateTime?
  dataFim      DateTime?
  cronograma   String?
  capacidade   Int         @default(16)
  status       StatusTurma @default(PLANEJADA)
  rolling      Boolean     @default(false) // Pré A1 (entrada contínua) — A1 herda janela maior
  criadoEm     DateTime    @default(now())

  alocacoes AlocacaoTurma[]
}

// ============================================================
// ALUNOS
// ============================================================

enum StatusAluno {
  ATIVO
  PAUSADO
  ENCERRADO
}

// Gênero (doc 09 §Identificação): lista curta — Masculino · Feminino · Prefiro não informar.
// (V0 tinha OUTRO; removido na migration `aluno_cadastro_completo`, OUTRO→NAO_INFORMADO.)
enum Genero {
  MASCULINO
  FEMININO
  NAO_INFORMADO // rótulo na UI: "Prefiro não informar"
}

// Escolaridade do aluno (doc 09 §Acadêmico). Lista fechada, ordem crescente.
enum Escolaridade {
  FUNDAMENTAL_INCOMPLETO
  FUNDAMENTAL_COMPLETO
  MEDIO_INCOMPLETO
  MEDIO_COMPLETO
  TECNICO
  SUPERIOR_INCOMPLETO
  SUPERIOR_COMPLETO
  POS_GRADUACAO
  MESTRADO
  DOUTORADO
}

// Cadastro de pessoa guiado pelo país (doc 04 §espinha dorsal). O `paisId` é o país-base
// (mercado) que comanda tipos de documento, DDI do telefone e moeda da matrícula.
// Nacionalidade / 2ª nacionalidade / país de residência / país emissor são ISO 3166
// (qualquer país — ver `lib/paises-iso.ts`), pois não são mercados da Genius.
model Aluno {
  id              String      @id @default(cuid())
  codigo          String?     @unique // A-000001

  // Identificação (doc 09 §Identificação). `nome` foi dividido em primeiroNome+sobrenome
  // na migration `aluno_cadastro_completo` (backfill: split no 1º espaço).
  primeiroNome    String
  sobrenome       String?
  nomePreferido   String?
  nascimento      DateTime?
  genero          Genero?

  // Documentação — país dirige o tipo de documento e a validação (doc 04).
  paisId          String
  pais            Pais           @relation(fields: [paisId], references: [id])
  tipoDocumentoId String?
  tipoDocumento   TipoDocumento? @relation(fields: [tipoDocumentoId], references: [id])
  documento       String? // número do documento
  documentoValido Boolean        @default(false)
  documentoPaisEmissor String? // ISO 3166 (opcional) — permite documento estrangeiro
  nacionalidade        String? // ISO 3166
  segundaNacionalidade String? // ISO 3166 (opcional)

  // Contato — telefone/e-mail bloqueiam se inválidos (doc 04 §3).
  email              String?
  telefoneE164       String? // E.164 com DDI embutido (ex.: +50688887777). Máscara só na UI.
  whatsapp           Boolean @default(false) // o telefone principal é WhatsApp?
  aceitaComunicacoes Boolean @default(true) // opt-in de comunicações

  // Residência (doc 09 §Residência) — país pode diferir da nacionalidade (comum na AC).
  paisResidencia String? // ISO 3166
  cep            String?
  rua            String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  regiao         String? // Estado / Província / Departamento (nome varia por país)

  // Acadêmico (doc 09 §Acadêmico)
  escolaridade Escolaridade?
  idiomaNativo String?

  // Operacional (doc 09 §Operacional)
  fuso        String? // sobrescreve o fuso do país (envio de mensagens); default = país
  observacoes String?

  // Estado
  status   StatusAluno @default(ATIVO)
  criadoEm DateTime    @default(now())

  responsaveis  AlunoResponsavel[]
  matriculas    Matricula[]
  alocacoes     AlocacaoTurma[]
  movimentacoes MovimentacaoAluno[]
}

model Responsavel {
  id           String  @id @default(cuid())
  nome         String
  parentesco   String?
  telefoneE164 String?
  email        String?

  alunos AlunoResponsavel[]
}

enum PapelResponsavel {
  PEDAGOGICO
  FINANCEIRO
  EMERGENCIA // contato de emergência (doc 09 §Operacional) — nome/parentesco/telefone
}

model AlunoResponsavel {
  id            String           @id @default(cuid())
  alunoId       String
  aluno         Aluno            @relation(fields: [alunoId], references: [id])
  responsavelId String
  responsavel   Responsavel      @relation(fields: [responsavelId], references: [id])
  papel         PapelResponsavel @default(FINANCEIRO)
}

model AlocacaoTurma {
  id       String   @id @default(cuid())
  alunoId  String
  aluno    Aluno    @relation(fields: [alunoId], references: [id])
  turmaId  String
  turma    Turma    @relation(fields: [turmaId], references: [id])
  ativa    Boolean  @default(true)
  criadoEm DateTime @default(now())

  // Integridade (issue #1): no máx. UMA alocação ATIVA por aluno. Índice único PARCIAL
  // (só linhas ativa=true) — Prisma não modela WHERE em @@unique, então mora na migration
  // `integridade_alocacao_preco` (UNIQUE ... WHERE "ativa"). Histórico (ativa=false) é livre.
  @@index([alunoId])
  @@index([turmaId])
}

// MOVIMENTAÇÃO DO ALUNO — tabela TIPADA (decisão P6, doc 15).
// Mesmo princípio do financeiro: Evento = auditoria; tabela tipada = relatório/operação.
// Responde "quantos pausaram/encerraram este mês", "por que está nessa turma", etc.
// (turmaOrigem/Destino ficam como IDs simples — é um log; aluno/usuário têm relação.)
enum TipoMovimentacao {
  MATRICULA
  TROCA_TURMA
  PAUSA
  REATIVACAO
  ENCERRAMENTO
}

model MovimentacaoAluno {
  id             String           @id @default(cuid())
  alunoId        String
  aluno          Aluno            @relation(fields: [alunoId], references: [id])
  tipo           TipoMovimentacao
  turmaOrigemId  String?
  turmaDestinoId String?
  statusOrigem   StatusAluno?
  statusDestino  StatusAluno?
  motivo         String?
  observacao     String?
  usuarioId      String?
  usuario        Usuario?         @relation("AutorMovimentacoes", fields: [usuarioId], references: [id])
  criadoEm       DateTime         @default(now())

  @@index([alunoId])
  @@index([tipo])
  @@index([criadoEm])
}

// ============================================================
// COMERCIAL (LEAD)
// ============================================================

enum Temperatura {
  QUENTE
  MORNO
  FRIO
}

enum EtapaLead {
  NOVO
  EM_ATENDIMENTO
  QUALIFICADO
  EXPERIMENTAL_AGENDADA
  EXPERIMENTAL_REALIZADA
  PROPOSTA
  AGUARDANDO_MATRICULA
  MATRICULADO
  NO_SHOW
  PERDIDO
}

enum MotivoPerda {
  NAO_RESPONDEU
  PRECO
  TEMPO
  CONCORRENCIA
  INTERESSE
  LOCALIZACAO
  EMPRESA
  QUALIFICACAO
  OUTRO
}

model Lead {
  id             String      @id @default(cuid())
  codigo         String?     @unique // L-000001
  nome           String
  telefoneE164   String?
  paisId         String?
  pais           Pais?       @relation(fields: [paisId], references: [id])
  segmento       Segmento    @default(ADULTO)
  temperatura    Temperatura @default(MORNO)
  etapa          EtapaLead   @default(NOVO)
  b2b            Boolean     @default(false)
  vendedorDonoId String?
  vendedor       Usuario?    @relation("VendedorLeads", fields: [vendedorDonoId], references: [id])

  // Professor responsável pela experimental (Issue #13). FK opcional (NULL) =
  // sem atribuição: experimentais antigas/sem professor ficam sem escopo até
  // serem (re)atribuídas. Fonte de verdade do vínculo professor↔experimental;
  // o evento `ExperimentalAtribuida` é mantido apenas para auditoria.
  professorExperimentalId String?
  professorExperimental   Usuario? @relation("ProfessorExperimentais", fields: [professorExperimentalId], references: [id])

  // origem inteligente
  origemCampanha String?
  origemConjunto String?
  origemAnuncio  String?
  origemPalavra  String?

  // resumo executivo (manual no V0, IA na Fase 1)
  interesse   String?
  objetivo    String?
  urgencia    String?
  orcamento   String?
  objecao     String?
  proximaAcao String?

  // datas que alimentam a fila da Home
  proximoFollowUp  DateTime?
  dataExperimental DateTime?
  dataProposta     DateTime?

  // valor da oportunidade (Ficha do Lead — doc 09)
  valorPrevisto    Float?
  planoPrevisto    String?
  comissaoPrevista Float?

  motivoPerda    MotivoPerda?
  ultimaCobranca DateTime?
  criadoEm       DateTime     @default(now())

  matricula  Matricula?
  documentos Documento[]
}

enum CategoriaDocumento {
  PROPOSTA
  CONTRATO
  COMPROVANTE
  TESTE_NIVEL
  OUTRO
}

// Documentos anexados ao lead (Propostas/Contratos/Comprovantes/Teste de nível — doc 09).
model Documento {
  id        String             @id @default(cuid())
  leadId    String
  lead      Lead               @relation(fields: [leadId], references: [id])
  categoria CategoriaDocumento
  nome      String
  url       String
  arquivado Boolean            @default(false) // soft-delete (doc 10 §6: ninguém apaga nada)
  criadoEm  DateTime           @default(now())

  @@index([leadId])
}

// ============================================================
// MATRÍCULA / FINANCEIRO
// ============================================================

enum StatusMatricula {
  RASCUNHO
  AGUARDANDO
  ATIVA
  ENCERRADA
  CANCELADA // encerramento precoce → estorno de comissão (ver docs/10)
}

model Matricula {
  id                    String          @id @default(cuid())
  alunoId               String
  aluno                 Aluno           @relation(fields: [alunoId], references: [id])
  leadId                String?         @unique
  lead                  Lead?           @relation(fields: [leadId], references: [id])
  produtoId             String
  produto               Produto         @relation(fields: [produtoId], references: [id])
  paisId                String
  pais                  Pais            @relation(fields: [paisId], references: [id])
  codigo                String?         @unique // M-000001
  moeda                 String
  status                StatusMatricula @default(RASCUNHO)
  diaVencimento         Int             @default(5)
  mesesPlano            Int             @default(12) // p/ gerar o cronograma na ativação
  // Gatilho de ativação (decisão P7, doc 15): ATIVA exige os três true.
  contratoOk            Boolean         @default(false)
  pagamentoTaxaOk       Boolean         @default(false)
  primeiraMensalidadeOk Boolean         @default(false)
  // Exceção: Admin/Gerente pode ativar com pendência (registra o porquê em Evento).
  ativadaComPendencia   Boolean         @default(false)
  // Exceção de preço auditável (Issues #7/#22): matrícula criada SEM preço de
  // referência ATIVO para a combinação país × produto × tipo de cobrança, por
  // exceção justificada + aprovada. Exige justificativa e grava Evento
  // `MatriculaSemPrecoReferencia`. Permite operar países/produtos sem matriz de
  // preços fechada (doc 06 §Em aberto) sem perder a auditoria.
  precoReferenciaAusente Boolean        @default(false)
  justificativaSemPreco  String?
  // Nível inicial + origem (doc 09 §Matrícula): de onde veio o nível do aluno.
  nivelInicialId        String?
  origemNivel           OrigemNivel?
  dataAvaliacaoNivel    DateTime?
  criadoEm              DateTime        @default(now())
  ativadaEm             DateTime?
  // Bloqueio de acesso à aula (régua de cobrança D+15, doc 24). Flag ortogonal ao status:
  // a matrícula segue ATIVA, só perde acesso. Exige aprovação humana (Gerente Com./Admin);
  // o enforcement técnico (barrar entrada na aula) é Fase 1+ — aqui grava-se a decisão.
  acessoBloqueado       Boolean         @default(false)
  bloqueadoEm           DateTime?

  cobrancas Cobranca[]
  comissoes Comissao[]
  ajustes   AjusteFinanceiro[]
}

enum OrigemNivel {
  AVALIACAO
  MANUAL
}

enum StatusCobranca {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADA
}

enum FormaPagamento {
  TRANSFERENCIA
  GREENPAY
  DINHEIRO
  CARTAO
}

model Cobranca {
  id             String          @id @default(cuid())
  codigo         String?         @unique // C-000001
  matriculaId    String
  matricula      Matricula       @relation(fields: [matriculaId], references: [id])
  tipo           TipoCobranca
  competencia    String? // "2026-06" para mensalidades
  valorOriginal  Float
  valorNegociado Float
  valorRecebido  Float?
  saldo          Float? // valorNegociado - valorRecebido
  moeda          String
  vencimento     DateTime
  status         StatusCobranca  @default(PENDENTE)
  pagoEm         DateTime?
  formaPagamento FormaPagamento?
  comprovanteUrl String?
  comprovanteNome String?
  comentario     String?
  criadoEm       DateTime        @default(now())
}

enum StatusComissao {
  PENDENTE
  APROVADA
  PAGA
  ESTORNADA
}

model Comissao {
  id                    String         @id @default(cuid())
  matriculaId           String
  matricula             Matricula      @relation(fields: [matriculaId], references: [id])
  vendedorId            String
  vendedor              Usuario        @relation(fields: [vendedorId], references: [id])
  percentual            Float
  valor                 Float
  moeda                 String
  status                StatusComissao @default(PENDENTE)
  dataPrevistaPagamento DateTime?
  pagaEm                DateTime?
  criadoEm              DateTime       @default(now())
}

// ============================================================
// APROVAÇÕES (engine genérica)
// ============================================================

enum TipoAprovacao {
  DESCONTO
  BOLSA
  ALTERACAO_VALOR
  PERDAO_DIVIDA
  COMISSAO_EXCEPCIONAL
}

enum StatusAprovacao {
  PENDENTE
  APROVADA
  REJEITADA
}

enum Vigencia {
  ESTA_COBRANCA
  PROXIMOS_MESES
  CONTRATO_INTEIRO
}

model Aprovacao {
  id            String          @id @default(cuid())
  tipo          TipoAprovacao
  status        StatusAprovacao @default(PENDENTE)
  solicitanteId String
  solicitante   Usuario         @relation("SolicitanteAprovacoes", fields: [solicitanteId], references: [id])
  aprovadorId   String?
  aprovador     Usuario?        @relation("AprovadorAprovacoes", fields: [aprovadorId], references: [id])
  alvoTipo      String // "Cobranca", "Comissao"...
  alvoId        String?
  payload       Json? // { de, para, percentual, ... }
  vigencia      Vigencia?
  motivo        String?
  impactoMensal Float?
  criadoEm      DateTime        @default(now())
  decididoEm    DateTime?
}

// ============================================================
// AJUSTE FINANCEIRO — tabela TIPADA (relatório). Evento cuida da auditoria.
// Responde: total de desconto concedido · desconto por vendedor / país / modalidade.
// ============================================================

enum TipoAjuste {
  DESCONTO
  BOLSA
  ALTERACAO_VALOR
  PERDAO
  RENEGOCIACAO
}

model AjusteFinanceiro {
  id            String     @id @default(cuid())
  matriculaId   String
  matricula     Matricula  @relation(fields: [matriculaId], references: [id])
  cobrancaId    String? // referência leve (opcional)
  tipo          TipoAjuste
  valorDe       Float
  valorPara     Float
  descontoValor Float // valorDe - valorPara
  descontoPct   Float?
  moeda         String
  vigencia      Vigencia?
  motivo        String
  autorId       String
  autor         Usuario    @relation("AutorAjustes", fields: [autorId], references: [id])
  aprovacaoId   String?
  // denormalizados p/ relatório fácil (group by):
  vendedorId    String?
  paisId        String?
  modalidadeId  String?
  criadoEm      DateTime   @default(now())

  @@index([vendedorId])
  @@index([paisId])
  @@index([modalidadeId])
  @@index([criadoEm])
}

// ============================================================
// CÂMBIO — cotações manuais p/ CONSOLIDAÇÃO gerencial (reporting-only, doc 04 §Câmbio).
// NUNCA toca a conta do aluno: cada cobrança fica na sua moeda. Pivô único = USD
// (`unidadesPorUsd` = quantas unidades da moeda equivalem a 1 USD; USD seria 1, não é gravado).
// Append-only por (moeda, vigenteEm): a leitura usa a cotação MAIS RECENTE por moeda, e o
// histórico permite reconstruir a taxa usada em cada relatório. Auditoria de "quem" no Evento.
// ============================================================

model TaxaCambio {
  id             String   @id @default(cuid())
  moeda          String // ISO 4217 (ex.: CRC, BRL). Alvo/origem de conversão; USD é o pivô.
  unidadesPorUsd Float // quantas unidades desta moeda equivalem a 1 USD (ex.: CRC ~ 512)
  vigenteEm      DateTime @default(now())
  criadoEm       DateTime @default(now())

  @@index([moeda, vigenteEm])
}

// ============================================================
// EVENTO — audit / event log append-only (ESPINHA DORSAL)
// ============================================================

model Evento {
  id           String   @id @default(cuid())
  tipo         String // LeadCriado, MatriculaAtivada, PagamentoRegistrado, AlunoPausado...
  agregadoTipo String // "Lead", "Matricula", "Aluno", "Cobranca"...
  agregadoId   String
  autorId      String?
  autor        Usuario? @relation("AutorEventos", fields: [autorId], references: [id])
  versao       Int      @default(1) // versão do formato do payload — versionamento salva vidas
  payload      Json? // { de, para, motivo, ... } — o antes→depois
  criadoEm     DateTime @default(now())

  @@index([agregadoTipo, agregadoId])
  @@index([tipo])
  @@index([criadoEm])
}

// ============================================================
// CONTADOR — gera os códigos legíveis (L-/A-/M-/C-/T-) sem corrida (transacional)
// ============================================================

model Contador {
  chave String @id // "lead", "aluno", "matricula", "cobranca", "turma"
  valor Int    @default(0)
}
